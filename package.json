{
  "name": "h3yun-cmax",
  "displayName": "H3Yun CMax",
  "description": "氚云低代码平台二开代码同步工具 - 自动从氚云平台同步应用代码到本地,实现版本管理和AI辅助开发",
  "version": "0.0.1",
  "publisher": "h3yun",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "h3yun-cmax.buildProject",
        "title": "从氚云构建项目"
      },
      {
        "command": "h3yun-cmax.syncProject",
        "title": "从氚云同步"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "h3yun-cmax.buildProject"
        },
        {
          "command": "h3yun-cmax.syncProject",
          "when": "explorerResourceIsFolder"
        }
      ],
      "explorer/context": [
        {
          "command": "h3yun-cmax.syncProject",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "ts-loader": "^9.4.0",
    "vue-loader": "^17.2.0",
    "@vue/compiler-sfc": "^3.3.0",
    "sass": "^1.63.0",
    "sass-loader": "^13.3.0",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.0",
    "@vscode/vsce": "^2.21.0"
  }
}
